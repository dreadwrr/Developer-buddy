#!/usr/bin/env bash
#inotify db5                     07/05/2026
# inotify to watching either / or /mnt/live/memory/changes. filters out some files and also browser suppressions in sbwr array. see rntchangesfunctions
# Also filters out app inclusions in inotifyexl array
# purpose to prepare hashed files that are downloads from a package manager or are copied files that have preserved
# metadata where ctime is greater than mtime. This is because they would not show up in a regular file search.
#
# result bypassing, one of two loops, the ctime loop. Any files over 1MB are cached for this script and the main search mtime loop
#SCRIPT_PATH="$( dirname "$0")"
#. "$SCRIPT_PATH"/rntchangesfunctions
. /usr/local/save-changesnew/rntchangesfunctions

MOUNT_FOLDERS=("mnt" "media")
MOUNTS_INCLUDE=("home")

inotifyexl() {
inclusion=(
    '.*/\.wh\.([^/]*)$'
    ".*/Downloads/${LCLMODULENAME}x"
    "/tmp/${LCLMODULENAME}x"
    "/tmp/rc/${LCLMODULENAME}_MDY"
    "/tmp/${LCLMODULENAME}_MDY_[^/]*/${LCLMODULENAME}x.+$"
    "/usr/local/save-changesnew/flth.csv"
    "/usr/local/save-changesnew/logs.gpg"
    "/usr/local/save-changesnew/recent.gpg"
    "/usr/local/save-changesnew/stats.gpg"
    "/usr/local/save-changesnew/ctimecache.gpg"
    "$output_file"
	"$cache_file"
    "$CACHE_F"
)
}

MAX_JOBS=8
IDLE=$(( MAX_JOBS / 2 ))
BRAND=`date +"MDY_%m-%d-%y-TIME_%R"|tr ':' '_'`

ch="/mnt/live/memory/changes"
fmt="%Y-%m-%d %H:%M:%S"

# These can be user set so get fromm recentchanges script. and default fallbacks in case cant find
efile="/opt/recentchanges/recentchanges"
logpst="/usr/local/save-changesnew/logs.gpg"				;    statpst="/usr/local/save-changesnew/stats.gpg"
pydbpst="/usr/local/save-changesnew/recent.gpg"			;    ctimecache="/usr/local/save-changesnew/ctimecache.gpg"  # search cache
email="john.doe@email.com"
rlt=""
rltt=""
rlttt=""
mail=""

output_file=$1  # main output
LCLMODULENAME="$2"
cache_file="$3"  # main script cache on decrypt for exclude
CACHE_F="$4"  # secondary output cache
CSZE="$5"
cdir="$6"
LOCKFILE="$7"
checkSUM="$8"
time=$9
min_span="${10}"  # set greater than time to increase capacity. 0 prevents log from being cleared. otherwise increase _time in /opt/porteus-scripts/recentchanges
debug_file="${11}"  # debug output of this script

match_found=0

debug_log="false"  # add debug

pblk_log_file=/tmp/output  # debug output of pblk

dpaths=()
declare -A mvfrm_pending
declare -A create_pending

retried=0
LIMIT=3
sleep_index=0
sleep_times=(0.125 0.225 0.5 2 4)
j=${sleep_times[sleep_index]}
prev_size=-1
incr=0

STRTTIME=$(date +%s)

get_inclusion "$efile"

:> $CACHE_F ; :> $pblk_log_file

minspan $output_file $time $min_span $debug_file

echo "$BRAND inotify started" >> $debug_file

pst=$PWD
ch="${ch%/}"
[[ -d $ch ]] && { cd $ch && abpath="$ch/" || exit ; } || { [[ ! -d $ch ]] && cd "/" && abpath="/" || exit ; }
cd $pst || exit

sbwr
inotifyexl
inclusion+=("$rlt" "$rltt" "$rlttt" "/usr/local/save-changesnew/ctimecache.gpg")

exec 200>"$LOCKFILE"

exclude="^(proc|sys|dev|run"
for fld in "${MOUNT_FOLDERS[@]}"; do exclude+="|$fld" ; done
exclude+="|^/tmp/${LCLMODULENAME}_MDY_.*-TIME_.*(/.*)?\$"  # created by main script
exclude+=")"
# search in / or changes

timeout "$time" inotifywait -m -r --exclude "$exclude" -e create -e moved_to -e moved_from --format '%e|%c|%w%f%0' $abpath | while read -r -d '' o; do

    [[ "$debug_log" = "true" ]] && log_date=$(date +"$fmt")

    event=${o%%|*}
    o=${o#*|}
    cookie=${o%%|*}  # pairs a moved from event to a moved to event. src -> dest
    o=${o#*|}

    if [[ $abpath != "/" ]]; then o="${o#$ch}" ; fi

    log_lineout $debug_log $debug_file "$log_date" "File event: $event file: $o"

    if [[ -d "$o" ]]; then
        log_lineout $debug_log $debug_file "$log_date" "Directory created: $o"
        #incase the file is created at the same time ie scripts or a process and could be missed by intoify. however during testing -r captures it
        #find "$o" -cmin -5 -not -type d -printf '%T@ %A@ %C@ %i %M %n %s %u %g %m %p\0' |
        #while IFS= read -r -d '' record; do
        #    if [[ "$o" =~ \.(tmp|swp|bak|part|crdownload|partial|lock)$ ]]; then continue ; fi  
        #    echo "$log_date found new file in dir $o" >> /tmp/inotify.log
        #    sblk "$record" "$output_file" "/dev/null" "$checkSUM" "$xMODE" "$CACHE_F"
        #done
        continue

    elif [[ -f "$o" ]]; then

        log_lineout $debug_log $debug_file "$log_date" "inotify found checking for matches $o"

        match_found=0
        for item in "${webb[@]}"; do
            if [[ "$o" =~ $item ]]; then
                match_found=1
                break
            fi
        done
        if (( match_found == 0 )); then
            for item in "${inclusion[@]}"; do
                if [[ "$o" =~ $item ]]; then
                    match_found=1
                    break
                fi
            done
        fi

        # a CREATE event should match a MOVED_TO event
        # but there can be cases where the CREATE event wasnt seen or lost so it logs
        if [[ "$event" = "CREATE" ]]; then
            create_pending[$o]=1
        elif [[ "$event" = "MOVED_FROM" ]]; then
            mvfrm_pending["$cookie"]="$o"  # this is needed in the MOVED_TO event so can verify the src from the MOVED_FROM to a CREATE event. normal operation is verify dest as it would match in most cases from web browsers ect
            continue
        fi

        if [[ "$o" == *.* ]]; then
            ext="${o##*.}"
            ext="${ext,,}"
            if [[ "$ext" =~ ^(tmp|temp|swp|bak|part|crdownload|partial|lock)$ ]]; then
                continue
            fi
        fi

        if [[ "$event" = "MOVED_TO" ]]; then
            src="${mvfrm_pending[$cookie]}"
            if [[ -n "$src" ]]; then
                unset 'mvfrm_pending[$cookie]'
                if [[ -v create_pending[$src] ]]; then
                    unset 'create_pending[$src]'
                    log_lineout $debug_log $debug_file "$log_date" "inotify MOVED_TO unusual src was in create_pending on move after created file. src: $src dest or file: $o"
                # normal
                else
                    pairhandle ; continue
                fi
            # normal
            else
                pairhandle ; continue
            fi
        fi

        if (( match_found == 0 )); then

            current_jobs=$(jobs -r | wc -l)

            (
                if [[ "$event" = "CREATE" ]]; then
                    if (( current_jobs > IDLE )); then
                        log_lineout $debug_log $debug_file "$log_date" "system at has idle jobs: ($current_jobs) skipping stabilization wait $o"
                    else
                        curr_size=0
                        prev_size=-1
                        incr=0
                        retried=0
                        sleep_index=0

                        log_lineout $debug_log $debug_file "$log_date" "notify matched input to pblk waiting for stable size $o"

                        stable=0
                        while :; do
                            (( incr++ ))
                            curr_size=$(stat -c %s "$o" 2>/dev/null || echo -1)
                            (( curr_size < 0 )) && break  # Nosuchfile
                            if (( curr_size == prev_size )); then
                                (( retried++ ))
                                [[ $retried -ge $LIMIT ]] && stable=1 && break  # found
                                sleep_index=0
                                j=${sleep_times[0]}
                            else
                                retried=0
                                (( sleep_index < ${#sleep_times[@]} - 1 )) && ((sleep_index++))
                                j=${sleep_times[sleep_index]}
                            fi
                            prev_size="$curr_size" && sleep $j
                        done
                        [[ "$debug_log" = "true" ]] && log_date=$(date +"$fmt")
                        (( $curr_size )) || { log_lineout $debug_log $debug_file "$log_date" "inotify size stabilized looks like a download 0 bytes. returning for move event. file:$o" ; exit ; }

                        if (( stable == 1 )); then
                            log_lineout $debug_log $debug_file "$log_date" "inotify size stabilized for pblk $o"
                        else
                            log_lineout $debug_log $debug_file "$log_date" "inotify timed out waiting for stable size, proceeding anyway (checksum will self-guard): $o"
                        fi
                    fi
                fi

                { find "$o" -printf "%T@ %A@ %C@ %i %M %n %s %u %g %m %p|%l\0" 2>/dev/null; } |
                while IFS= read -r -d '' record; do
                    [[ -z "$record" ]] && continue

                    pblk "$record" "$output_file" "/dev/null" $checkSUM $CSZE "$CACHE_F" "$cdir" $debug_log "$pblk_log_file"

                done

            ) &
            while (( $(jobs -r | wc -l) >= MAX_JOBS )); do
                wait -n 2>/dev/null || sleep 0.1
            done

        else
            log_lineout $debug_log $debug_file "$log_date" "inotify found excluded by matching skipped. for $o"
        fi
     else
        log_lineout $debug_log $debug_file "$log_date" "inotify file not found or parsing error. for $o"
    fi
done

